// Problem: Check if array is sorted

#include <iostream>
#include <vector>
using namespace std;

bool isSorted(vector<int>& nums){
    int n = nums.size();

    for(int i = 0; i < n-1; i++){
        if(nums[i] > nums[i+1]){
            return false;
        }
    }
    return true;
}

int main(){
    vector<int> nums = {1, 2, 3, 4, 5};

    if(isSorted(nums))
        cout << "Array is Sorted";
    else
        cout << "Array is Not Sorted";

    return 0;
}
